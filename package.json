{
    "name": "trauma-transformation-institute",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "frontend:start": "cd frontend && npm start",
        "frontend:build": "cd frontend && npm run build",
        "backend:start": "cd backend && uvicorn server:app --reload",
        "deploy": "vercel --prod",
        "build": "cd frontend && npm install --legacy-peer-deps && npm run build",
        "start": "cd frontend && npm start"
    },
    "engines": {
        "node": "20.x"
    }
}